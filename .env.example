# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin / Agents
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
JWT_SECRET=your_jwt_secret

# API
API_PORT=4000
API_HOST=0.0.0.0
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

ADMIN_ALLOWED_ROLES=admin,moderator
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Wasabi S3
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com
WASABI_BUCKET=your_bucket_name
WASABI_ACCESS_KEY_ID=your_wasabi_access_key
WASABI_SECRET_ACCESS_KEY=your_wasabi_secret_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=GhanaDeals <notifications@yourdomain.com>
WEB_URL=http://localhost:3000
AGENTS_URL=http://localhost:3002

# Google Maps (Places Autocomplete + Interactive Map)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Error Tracking (Sentry)
SENTRY_DSN=your_sentry_dsn
